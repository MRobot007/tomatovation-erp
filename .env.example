# Copy to .env.local and fill in from your Supabase project:
#   Dashboard -> Project Settings -> API
#
# Both values are safe to expose in the browser bundle. The anon key is
# constrained by Row Level Security — it is NOT a secret. Never put the
# service_role key in this file or anywhere under src/.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only needed to run the live integration suites (npm run test:integration).
# The suites sign into pre-provisioned @example.com fixture accounts; this is
# the password they were provisioned with. It has no default in code on
# purpose — a literal in the test files would be published with the repo.
RLS_FIXTURE_PASSWORD=
